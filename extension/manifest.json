{
  "manifest_version": 3,
  "name": "TabMind",
  "version": "1.0.0",
  "description": "Save tabs. AI tags them. Find anything instantly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs", "storage", "identity"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://tab-mind.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
